{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "gamingsite",
	"compatibility_date": "2026-05-30",
	"observability": {
		"enabled": true
	},
	"main": ".svelte-kit/cloudflare/_worker.js",
	"assets": {
		"binding": "ASSETS",
		"directory": ".svelte-kit/cloudflare"
	},
	"compatibility_flags": ["nodejs_compat"]
}
